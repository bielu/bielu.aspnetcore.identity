@page "/login"
@inject NavigationManager Navigation

<PageTitle>Login</PageTitle>

<h1>Login</h1>

<p>Sign in using your <strong>local</strong> or <strong>LDAP</strong> credentials, or use <strong>Microsoft Entra ID</strong>.</p>

@if (!string.IsNullOrEmpty(_error))
{
    <div style="color: red; margin-bottom: 1rem;">⚠️ @_error</div>
}

<div style="display: flex; gap: 2rem; flex-wrap: wrap;">
    @* ── Local / LDAP login form ──────────────────────────────────── *@
    <div style="flex: 1; min-width: 300px;">
        <h3>Username &amp; Password</h3>
        <p style="color: #666; font-size: 0.9rem;">
            Tries LDAP first, then falls back to local account.
        </p>

        @* Login is handled via a POST endpoint because interactive Blazor Server
           components cannot set authentication cookies from @onclick handlers. *@
        <form method="post" action="/login">
            <AntiforgeryToken />

            <div style="margin-bottom: 0.5rem;">
                <label>Username</label><br />
                <input name="username" style="width: 100%; padding: 0.4rem;" />
            </div>
            <div style="margin-bottom: 0.5rem;">
                <label>Password</label><br />
                <input type="password" name="password" style="width: 100%; padding: 0.4rem;" />
            </div>

            <button type="submit" style="padding: 0.5rem 1.5rem;">
                Sign in
            </button>
        </form>

        <p style="margin-top: 1rem; font-size: 0.9rem;">
            Don't have a local account? <a href="/register">Register here</a>.
        </p>
    </div>

    @* ── Entra ID (OpenID Connect) ────────────────────────────────── *@
    <div style="flex: 1; min-width: 300px;">
        <h3>Microsoft Entra ID</h3>
        <p style="color: #666; font-size: 0.9rem;">
            Single sign-on via OpenID Connect.
        </p>

        <a href="/challenge/EntraId" style="display: inline-block; padding: 0.5rem 1.5rem;
               background: #0078d4; color: white; text-decoration: none; border-radius: 4px;">
            🔗 Sign in with Entra ID
        </a>
    </div>
</div>

@code {
    private string? _error;

    // Only these well-known error keys (set by the POST /login endpoint) are shown.
    // Arbitrary query-string values are not rendered to prevent phishing via crafted URLs.
    private static readonly Dictionary<string, string> AllowedErrors = new(StringComparer.OrdinalIgnoreCase)
    {
        ["Username+and+password+are+required"] = "Username and password are required.",
        ["Username and password are required"] = "Username and password are required.",
        ["Invalid+username+or+password"] = "Invalid username or password.",
        ["Invalid username or password"] = "Invalid username or password.",
        ["Account+is+locked+out"] = "Account is locked out.",
        ["Account is locked out"] = "Account is locked out.",
    };

    protected override void OnInitialized()
    {
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        if (Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query)
                .TryGetValue("error", out var errorValue))
        {
            var raw = errorValue.ToString();
            _error = AllowedErrors.GetValueOrDefault(raw, "An error occurred during sign-in.");
        }
    }
}
